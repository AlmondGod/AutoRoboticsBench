{
  "benchmark": {
    "allowed_edit_globs": [
      "program_autorobobench.md",
      "tasks/robocasa_language_following/**",
      "tasks/robocasa_language_following/inference.py",
      "tasks/robocasa_language_following/train.py"
    ],
    "higher_is_better": true,
    "immutable_globs": [
      "benchmark.json",
      "data/autorobobench/robocasa_language_following_manifest.json",
      "data/autorobobench/robocasa_language_following_splits.json",
      "tasks/robocasa_language_following/eval.py",
      "tasks/robocasa_language_following/setup.py",
      "tasks/robocasa_language_following/task.json"
    ],
    "notes": "Language-conditioned ChooseMeasuringCup track over four prompt variants: left/right drawer and larger/smaller cup.",
    "phase": 1,
    "primary_metric": "language_success_val_mse_score",
    "reference_metric": 0.7625,
    "required_result_keys": [
      "success_rate",
      "val_action_mse_score",
      "language_success_val_mse_score",
      "episodes",
      "successes"
    ],
    "score_weights": {
      "language_success_val_mse_score": 1.0
    },
    "starter_metric": 0.0
  },
  "default_eval": {
    "commit_steps": 8,
    "eval_episodes_per_task": 25,
    "max_steps": 900,
    "val_imitation_episodes_per_task": 2,
    "val_imitation_frames_per_episode": 8,
    "val_imitation_score_weight": 0.05
  },
  "eval": "tasks/robocasa_language_following/eval.py",
  "id": "robocasa_language_following",
  "inference": "tasks/robocasa_language_following/inference.py",
  "manifest": "data/autorobobench/robocasa_language_following_manifest.json",
  "metrics": {
    "primary": "language_success_val_mse_score",
    "secondary": [
      "language_success_rate",
      "success_rate",
      "val_action_mse",
      "val_action_mse_score",
      "wrong_language_success_rate",
      "conditioning_gap",
      "language_variant_balance",
      "per_task"
    ]
  },
  "name": "RoboCasa Language Following",
  "policy_interface": {
    "act": "act(policy, obs: dict, task: dict) -> np.ndarray[action_horizon, action_dim]",
    "commit_steps": "optional commit_steps(policy, task: dict, action_chunk: np.ndarray, default_commit_steps: int) -> int",
    "load_policy": "load_policy(checkpoint: str, device: str) -> policy"
  },
  "reference_metric": 0.7625,
  "setup": "tasks/robocasa_language_following/setup.py",
  "split": "data/autorobobench/robocasa_language_following_splits.json",
  "starter_metric": 0.0,
  "train": "tasks/robocasa_language_following/train.py",
  "train_contract": {
    "action_dim": 12,
    "eval_demos_per_variant": 25,
    "language_backbone": "HuggingFaceTB/SmolVLM2-500M-Video-Instruct",
    "policy_family": "frozen SmolVLM + flow action head",
    "robocasa_task": "ChooseMeasuringCup",
    "single_model": true,
    "test_time_demo_access": false,
    "train_demos_per_variant": 16,
    "train_language_variants": 4,
    "val_demos_per_variant": 2
  },
  "version": "v0",
  "visualize": "tasks/robocasa_language_following/visualize.py"
}
