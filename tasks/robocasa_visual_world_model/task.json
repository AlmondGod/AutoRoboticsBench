{
  "benchmark": {
    "allowed_edit_globs": [
      "program_autorobobench.md",
      "tasks/robocasa_visual_world_model/**",
      "tasks/robocasa_visual_world_model/inference.py",
      "tasks/robocasa_visual_world_model/model.py",
      "tasks/robocasa_visual_world_model/train.py",
      "tasks/robocasa_visual_world_model/visualize_rollout.py",
      "tasks/robocasa_world_model/data.py",
      "tasks/robocasa_world_model/inverse_dynamics.py",
      "tasks/robocasa_world_model/model.py",
      "tasks/robocasa_world_model/video_repr.py"
    ],
    "higher_is_better": true,
    "immutable_globs": [
      "data/autorobobench/robocasa_bc5_splits.json",
      "data/robocasa5/manifest.json",
      "tasks/robocasa_visual_world_model/eval.py",
      "tasks/robocasa_visual_world_model/setup.py",
      "tasks/robocasa_visual_world_model/task.json"
    ],
    "notes": "Learned RoboCasa world-model track scored by closed-loop generated-visual policy-score correlation against stored real simulator evals, plus pixel/state/progress/success consistency.",
    "phase": 1,
    "primary_metric": "visual_world_model_score",
    "reference_metric": 0.8,
    "required_result_keys": [
      "visual_world_model_score",
      "eval_correlation_score",
      "visual_reconstruction_score",
      "next_state_score",
      "progress_score",
      "success_score",
      "reproducibility_integrity"
    ],
    "score_weights": {
      "eval_correlation_score": 0.5,
      "next_state_score": 0.1,
      "progress_score": 0.1,
      "success_score": 0.1,
      "visual_reconstruction_score": 0.2
    },
    "starter_metric": 0.0
  },
  "default_train": {
    "frame_stride": 1,
    "image_size": 64,
    "image_vae_weight": 0.25,
    "inverse_align_weight": 0.0,
    "latent_dim": 64,
    "rollout_horizon": 4,
    "rollout_progress_weight": 0.05,
    "rollout_state_weight": 0.1,
    "rollout_visual_weight": 0.25,
    "max_train_seconds": 300,
    "train_episodes_per_task": 0,
    "val_episodes_per_task": 5,
    "view": "robot0_agentview_right",
    "visual_decoder_depth": 3,
    "visual_decoder_width": 512,
    "visual_latent_weight": 0.5,
    "visual_latent_dim": 128,
    "visual_lr_scale": 0.5,
    "visual_weight": 1.0,
    "image_augment": 0.15
  },
  "eval": "tasks/robocasa_visual_world_model/eval.py",
  "id": "robocasa_visual_world_model",
  "inference": "tasks/robocasa_visual_world_model/inference.py",
  "manifest": "data/robocasa5/manifest.json",
  "metrics": {
    "primary": "visual_world_model_score",
    "score_weights": {
      "eval_correlation_score": 0.5,
      "next_state_score": 0.1,
      "progress_score": 0.1,
      "success_score": 0.1,
      "visual_reconstruction_score": 0.2
    },
    "secondary": [
      "eval_correlation_score",
      "visual_perceptual_score",
      "visual_reconstruction_score",
      "next_state_score",
      "progress_score",
      "success_score",
      "policy_score_pearson",
      "policy_score_spearman",
      "ood_policy_score_pearson",
      "ood_policy_score_spearman",
      "next_rgb_lpips",
      "next_rgb_mse",
      "next_rgb_psnr",
      "next_state_mse_norm",
      "next_progress_mse",
      "success_bce"
    ]
  },
  "name": "RoboCasa Visually Accurate World Model",
  "reference_metric": 0.8,
  "setup": "tasks/robocasa_visual_world_model/setup.py",
  "split": "data/autorobobench/robocasa_bc5_splits.json",
  "starter_metric": 0.0,
  "train": "tasks/robocasa_visual_world_model/train.py",
  "train_contract": {
    "base_architecture": "state/action latent dynamics plus image VAE latent prediction",
    "default_action_labeled_train_rollouts_per_task": 20,
    "default_eval_rollouts_per_task": 5,
    "eval_tasks": 5,
    "heldout_visual_eval": true,
    "input": "state_t, action_t, current RGB frame_t",
    "inverse_dynamics_auxiliary_allowed": true,
    "latent_prediction_allowed": true,
    "primary_eval": "closed_loop_visual_policy_score_correlation_with_stored_real_sim_success",
    "primary_visual_metric": "pixel MSE score; LPIPS is reported as a secondary diagnostic",
    "rgb_reconstruction_allowed": true,
    "targets": [
      "next_rgb_frame conditioned on current RGB",
      "next_state",
      "next_task_progress",
      "task_success"
    ],
    "train_tasks": 5,
    "vae_allowed": true,
    "video_only_pretraining_allowed": true
  },
  "version": "v0",
  "world_model_interface": {
    "load_world_model": "load_world_model(checkpoint: str, device: str) -> dict",
    "predict_next": "predict_next(world_model, state, action, current_rgb=None) -> dict with next_rgb"
  },
  "visualize": "tasks/robocasa_visual_world_model/visualize.py"
}
