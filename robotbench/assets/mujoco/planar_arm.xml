<mujoco model="robot_autoresearch_planar_arm">
  <compiler angle="radian" inertiafromgeom="true"/>
  <option timestep="0.01" gravity="0 0 -9.81" integrator="RK4"/>
  <visual>
    <global offwidth="720" offheight="720"/>
  </visual>

  <default>
    <geom friction="1.0 0.005 0.0001" solref="0.02 1" solimp="0.9 0.95 0.001"/>
    <joint damping="0.12" armature="0.01"/>
    <motor ctrllimited="true" ctrlrange="-1 1"/>
  </default>

  <asset>
    <material name="mat_floor" rgba="0.86 0.87 0.88 1"/>
    <material name="mat_link" rgba="0.12 0.35 0.62 1"/>
    <material name="mat_tip" rgba="0.05 0.48 0.72 1"/>
    <material name="mat_obj" rgba="0.95 0.45 0.08 1"/>
    <material name="mat_target" rgba="0.1 0.7 0.18 0.65"/>
  </asset>

  <worldbody>
    <light name="key" pos="0 -1.6 2.4" dir="0 0.7 -1" diffuse="0.8 0.8 0.8"/>
    <camera name="top" pos="0 0 2.2" xyaxes="1 0 0 0 1 0"/>
    <geom name="floor" type="plane" size="1.4 1.4 0.02" material="mat_floor"/>

    <body name="target" pos="0.55 0.25 0.025">
      <geom name="target_geom" type="cylinder" size="0.055 0.006" material="mat_target" contype="0" conaffinity="0"/>
    </body>

    <body name="object" pos="0.15 0.0 0.035">
      <freejoint name="object_free"/>
      <geom name="object_geom" type="cylinder" size="0.045 0.035" mass="0.12" material="mat_obj"/>
    </body>

    <body name="base" pos="0 0 0.045">
      <geom name="base_geom" type="cylinder" size="0.055 0.035" rgba="0.08 0.08 0.08 1"/>
      <joint name="shoulder" type="hinge" axis="0 0 1" range="-3.14 3.14"/>
      <geom name="link1_geom" type="capsule" fromto="0 0 0 0.38 0 0" size="0.025" material="mat_link"/>
      <body name="elbow" pos="0.38 0 0">
        <joint name="elbow" type="hinge" axis="0 0 1" range="-3.14 3.14"/>
        <geom name="link2_geom" type="capsule" fromto="0 0 0 0.32 0 0" size="0.022" material="mat_link"/>
        <body name="tip" pos="0.32 0 0">
          <geom name="tip_geom" type="sphere" size="0.04" mass="0.04" material="mat_tip"/>
          <site name="ee_site" pos="0 0 0" size="0.025" rgba="0.05 0.48 0.72 1"/>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="shoulder_motor" joint="shoulder" gear="1.8"/>
    <motor name="elbow_motor" joint="elbow" gear="1.5"/>
  </actuator>
</mujoco>
